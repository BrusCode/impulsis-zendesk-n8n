{
  "name": "Impulsis - Roteamento Seguro v2",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "impulsis-retorno-routing-v2",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "w1-webhook",
      "name": "Webhook - Novo Contato",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [220, 320]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"status\": \"ok\", \"ticket\": $json.ticket_id } }}",
        "options": {}
      },
      "id": "w1-response",
      "name": "Resposta 200",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [420, 150]
    },
    {
      "parameters": {
        "url": "=https://webposto.zendesk.com/api/v2/search.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "=type:ticket requester:{{ $json.requester_id }} tags:impulsis_ativo status String(t.id) !== String(wh.ticket_id) && ['open','pending','hold'].includes(t.status) && Array.isArray(t.tags) && t.tags.includes('impulsis_ativo'));\nif (!origin) { return [{ json: { found: false, reason: 'origin_not_found', new_ticket_id: wh.ticket_id, requester_id: wh.requester_id } }]; }\nreturn [{ json: { found: true, new_ticket_id: wh.ticket_id, requester_id: wh.requester_id, origin_ticket_id: origin.id, origin_subject: origin.subject, assignee_id: origin.assignee_id } }];"
      },
      "id": "w1-extract-origin",
      "name": "Extrair Origem",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 320]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            { "leftValue": "={{ $json.found }}", "rightValue": true, "operator": { "type": "boolean", "operation": "true" } }
          ],
          "combinator": "and"
        }
      },
      "id": "w1-if-origin",
      "name": "Origem Encontrada?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [870, 320]
    },
    {
      "parameters": {
        "url": "=https://webposto.zendesk.com/api/v2/search.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "=type:ticket requester:{{ $json.requester_id }} status String(t.id) !== String(ctx.new_ticket_id) && ['open','pending','hold'].includes(t.status) && Array.isArray(t.custom_fields) && t.custom_fields.some(f => String(f.id) === '41306351713940' && String(f.value) === String(ctx.origin_ticket_id)));\nreturn [{ json: { ...ctx, duplicate_child_found: !!duplicate, duplicate_child_id: duplicate ? duplicate.id : null } }];"
      },
      "id": "w1-check-duplicate",
      "name": "Validar Filho Ativo Existente",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1310, 230]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            { "leftValue": "={{ $json.duplicate_child_found }}", "rightValue": false, "operator": { "type": "boolean", "operation": "false" } }
          ],
          "combinator": "and"
        }
      },
      "id": "w1-if-duplicate",
      "name": "Já Existe Filho Ativo?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1530, 230]
    },
    {
      "parameters": {
        "url": "=https://webposto.zendesk.com/api/v2/users/{{ $('Extrair Origem').first().json.assignee_id }}.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "options": {}
      },
      "id": "w1-get-agent",
      "name": "Buscar Agente",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1750, 120],
      "credentials": { "httpBasicAuth": { "id": "ZENDESK_BASIC_AUTH", "name": "Zendesk Basic Auth" } }
    },
    {
      "parameters": {
        "jsCode": "const agent = $input.first().json.user;\nconst ctx = $('Extrair Origem').first().json;\nconst nota = [\n`🔄 Retorno Impulsis roteado automaticamente.`,\n``,\n`Ticket de origem: #${ctx.origin_ticket_id} (${ctx.origin_subject})`,\n`Agente responsável: ${agent.name} <${agent.email}>`,\n``,\n`Este ticket foi vinculado automaticamente ao ciclo ativo do disparo.`\n].join('\\n');\nreturn [{ json: { ...ctx, agent_name: agent.name, agent_email: agent.email, nota_interna: nota } }];"
      },
      "id": "w1-prepare",
      "name": "Preparar Atualização",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1970, 120]
    },
    {
      "parameters": {
        "url": "=https://webposto.zendesk.com/api/v2/tickets/{{ $json.new_ticket_id }}.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "method": "PUT",
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ ticket: { assignee_id: $json.assignee_id, status: 'open', tags: ['impulsis_retorno','roteado_agente_automatico'], custom_fields: [ { id: 41306351713940, value: String($json.origin_ticket_id) }, { id: 41270897374356, value: true } ], comment: { body: $json.nota_interna, public: false } } }) }}",
        "options": {}
      },
      "id": "w1-update-new",
      "name": "Atualizar Ticket Novo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2190, 120],
      "credentials": { "httpBasicAuth": { "id": "ZENDESK_BASIC_AUTH", "name": "Zendesk Basic Auth" } }
    },
    {
      "parameters": {
        "url": "=https://webposto.zendesk.com/api/v2/tickets/{{ $('Preparar Atualização').first().json.origin_ticket_id }}.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "method": "PUT",
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ ticket: { custom_fields: [ { id: 41270881369364, value: true } ], comment: { body: '✅ Novo ticket #' + $('Preparar Atualização').first().json.new_ticket_id + ' foi vinculado automaticamente a este ticket como retorno ativo.', public: false } } }) }}",
        "options": {}
      },
      "id": "w1-update-origin",
      "name": "Atualizar Ticket Original",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2410, 120],
      "credentials": { "httpBasicAuth": { "id": "ZENDESK_BASIC_AUTH", "name": "Zendesk Basic Auth" } }
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { status: 'skipped_duplicate_child', origin_ticket_id: $json.origin_ticket_id, duplicate_child_id: $json.duplicate_child_id, new_ticket_id: $json.new_ticket_id } }];"
      },
      "id": "w1-skip-duplicate",
      "name": "Log Duplicidade",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1750, 350]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { status: 'origin_not_found', payload: $input.first().json } }];"
      },
      "id": "w1-skip-origin",
      "name": "Log Sem Origem",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1090, 450]
    }
  ],
  "connections": {
    "Webhook - Novo Contato": { "main": [[{ "node": "Resposta 200", "type": "main", "index": 0 }, { "node": "Buscar Ticket Original", "type": "main", "index": 0 }]] },
    "Buscar Ticket Original": { "main": [[{ "node": "Extrair Origem", "type": "main", "index": 0 }]] },
    "Extrair Origem": { "main": [[{ "node": "Origem Encontrada?", "type": "main", "index": 0 }]] },
    "Origem Encontrada?": { "main": [[{ "node": "Buscar Ticket Filho Ativo", "type": "main", "index": 0 }],[{ "node": "Log Sem Origem", "type": "main", "index": 0 }]] },
    "Buscar Ticket Filho Ativo": { "main": [[{ "node": "Validar Filho Ativo Existente", "type": "main", "index": 0 }]] },
    "Validar Filho Ativo Existente": { "main": [[{ "node": "Já Existe Filho Ativo?", "type": "main", "index": 0 }]] },
    "Já Existe Filho Ativo?": { "main": [[{ "node": "Buscar Agente", "type": "main", "index": 0 }],[{ "node": "Log Duplicidade", "type": "main", "index": 0 }]] },
    "Buscar Agente": { "main": [[{ "node": "Preparar Atualização", "type": "main", "index": 0 }]] },
    "Preparar Atualização": { "main": [[{ "node": "Atualizar Ticket Novo", "type": "main", "index": 0 }]] },
    "Atualizar Ticket Novo": { "main": [[{ "node": "Atualizar Ticket Original", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": ["impulsis","zendesk","routing-v2"]
}
