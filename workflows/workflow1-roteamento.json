    {
      "parameters": {
        "jsCode": "const results = $input.first().json.results || [];\nconst wh = $('Webhook Novo Contato').first().json;\nconst origin = results.find(t =>\n  Array.isArray(t.tags) &&\n  t.tags.includes('impulsis_ativo') &&\n  ['open','pending','hold'].includes(t.status)\n);\nif (!origin) {\n  return [{ json: { found: false, reason: 'origin_not_found', new_ticket_id: wh.body.ticket_id, requester_id: wh.body.requester_id } }];\n}\nreturn [{ json: {\n  found: true,\n  new_ticket_id: wh.body.ticket_id,\n  requester_id: wh.body.requester_id,\n  origin_ticket_id: origin.id,\n  origin_subject: origin.subject,\n  assignee_id_fallback: origin.assignee_id\n} }];"
      },
