        "responseMode": "responseNode",
        "options": {}
      },
      "id": "w1-webhook",
      "name": "Webhook - Novo Contato",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        220,
        320
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"status\": \"ok\", \"ticket\": $json.ticket_id } }}",
        "options": {}
      },
      "id": "w1-response",
      "name": "Resposta 200",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        420,
        150
      ]
    },
    {
      "parameters": {
        "url": "=https://webposto.zendesk.com/api/v2/search.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "=type:ticket requester:{{ $json.requester_id }} tags:impulsis_ativo status\n  String(t.id) !== String(wh.ticket_id) &&\n  ['open','pending','hold'].includes(t.status) &&\n  Array.isArray(t.tags) &&\n  t.tags.includes('impulsis_ativo')\n);\nif (!origin) {\n  return [{ json: { found: false, reason: 'origin_not_found', new_ticket_id: wh.ticket_id, requester_id: wh.requester_id } }];\n}\nreturn [{ json: { found: true, new_ticket_id: wh.ticket_id, requester_id: wh.requester_id, origin_ticket_id: origin.id, origin_subject: origin.subject, assignee_id: origin.assignee_id } }];"
      },
      "id": "w1-extract-origin",
      "name": "Extrair Origem",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        650,
        320
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-found",
              "leftValue": "={{ $json.found }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "w1-if-origin",
      "name": "Origem Encontrada?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        870,
        320
      ]
    },
    {
      "parameters": {
        "url": "=https://webposto.zendesk.com/api/v2/search.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "=type:ticket requester:{{ $('Extrair Origem').first().json.requester_id }} tags:impulsis_retorno status\n  String(t.id) !== String(ctx.new_ticket_id) &&\n  ['open','pending','hold'].includes(t.status)\n);\nreturn [{ json: {\n  found: ctx.found,\n  new_ticket_id: ctx.new_ticket_id,\n  requester_id: ctx.requester_id,\n  origin_ticket_id: ctx.origin_ticket_id,\n  origin_subject: ctx.origin_subject,\n  assignee_id: ctx.assignee_id,\n  duplicate_child_found: !!duplicate,\n  duplicate_child_id: duplicate ? duplicate.id : null\n} }];"
      },
      "id": "w1-check-duplicate",
      "name": "Validar Filho Ativo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1310,
        230
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-dup",
              "leftValue": "={{ $json.duplicate_child_found }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "false"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "w1-if-duplicate",
      "name": "Ja Existe Filho Ativo?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1530,
        230
      ]
    },
    {
      "parameters": {
        "url": "=https://webposto.zendesk.com/api/v2/users/{{ $json.assignee_id }}.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "options": {}
      },
      "id": "w1-get-agent",
      "name": "Buscar Agente",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1750,
        120
      ],
      "credentials": {
        "httpBasicAuth": {
          "id": "ZENDESK_BASIC_AUTH",
          "name": "Zendesk Basic Auth"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const agent = $input.first().json.user;\nconst ctx = $('Validar Filho Ativo').first().json;\nconst nota = [\n  '🔄 Retorno Impulsis roteado automaticamente.',\n  '',\n  'Ticket de origem: #' + ctx.origin_ticket_id + ' (' + ctx.origin_subject + ')',\n  'Agente responsavel: ' + agent.name + ' <' + agent.email + '>',\n  '',\n  'Este ticket foi vinculado automaticamente ao ciclo ativo do disparo.'\n].join('\\n');\nreturn [{ json: {\n  new_ticket_id: ctx.new_ticket_id,\n  origin_ticket_id: ctx.origin_ticket_id,\n  origin_subject: ctx.origin_subject,\n  assignee_id: ctx.assignee_id,\n  agent_name: agent.name,\n  agent_email: agent.email,\n  nota_interna: nota\n} }];"
      },
      "id": "w1-prepare",
      "name": "Preparar Atualizacao",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1970,
        120
      ]
    },
    {
      "parameters": {
        "url": "=https://webposto.zendesk.com/api/v2/tickets/{{ $json.new_ticket_id }}.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "method": "PUT",
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ ticket: { assignee_id: $json.assignee_id, status: 'open', tags: ['impulsis_retorno','roteado_agente_automatico'], custom_fields: [ { id: 41306351713940, value: String($json.origin_ticket_id) }, { id: 41270897374356, value: true } ], comment: { body: $json.nota_interna, public: false } } }) }}",
        "options": {}
      },
      "id": "w1-update-new",
      "name": "Atualizar Ticket Novo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2190,
        120
      ],
      "credentials": {
        "httpBasicAuth": {
          "id": "ZENDESK_BASIC_AUTH",
          "name": "Zendesk Basic Auth"
        }
      }
    },
    {
      "parameters": {
        "url": "=https://webposto.zendesk.com/api/v2/tickets/{{ $('Preparar Atualizacao').first().json.origin_ticket_id }}.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "method": "PUT",
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ ticket: { custom_fields: [ { id: 41270881369364, value: true } ], comment: { body: '✅ Novo ticket #' + $('Preparar Atualizacao').first().json.new_ticket_id + ' vinculado automaticamente como retorno ativo.', public: false } } }) }}",
        "options": {}
      },
      "id": "w1-update-origin",
      "name": "Atualizar Ticket Original",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2410,
        120
      ],
      "credentials": {
        "httpBasicAuth": {
          "id": "ZENDESK_BASIC_AUTH",
          "name": "Zendesk Basic Auth"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const ctx = $json;\nreturn [{ json: { status: 'skipped_duplicate_child', origin_ticket_id: ctx.origin_ticket_id, duplicate_child_id: ctx.duplicate_child_id, new_ticket_id: ctx.new_ticket_id } }];"
      },
      "id": "w1-skip-duplicate",
      "name": "Log Duplicidade",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1750,
        360
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { status: 'origin_not_found', payload: $input.first().json } }];"
      },
      "id": "w1-skip-origin",
      "name": "Log Sem Origem",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1090,
        450
      ]
    }
  ],
